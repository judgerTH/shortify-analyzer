# DB 연결
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/shortify

# 중복 판별 모델 선택 (tfidf | sbert)
DEDUP_MODEL=tfidf

# TF-IDF 설정
# 실제 데이터 500건 테스트 결과: 0.90이 과탐지 없이 가장 안정적
TFIDF_THRESHOLD=0.90
TFIDF_MAX_FEATURES=10000

# 제목 가중치: 제목을 N배 반복하여 본문보다 강조 (권장: 3)
# 실험 결과: title_weight=3으로 최대 그룹 크기 55→20 감소
TITLE_WEIGHT=3

# 날짜 필터: 발행일 ±N일 내 기사끼리만 비교 (0=비활성화, 권장: 1)
DATE_WINDOW_DAYS=1

# SBERT 설정
SBERT_THRESHOLD=0.88
SBERT_MODEL_NAME=jhgan/ko-sroberta-multitask

# 본문 최대 길이 (토큰 절약용)
CONTENT_MAX_CHARS=500
